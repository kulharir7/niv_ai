{
    "name": "Niv MCP Server",
    "module": "Niv Core",
    "doctype": "DocType",
    "document_type": "Setup",
    "engine": "InnoDB",
    "field_order": [
        "server_name",
        "is_active",
        "column_break_1",
        "transport_type",
        "section_connection",
        "server_url",
        "column_break_2",
        "api_key",
        "section_status",
        "tools_count",
        "column_break_3",
        "last_connected",
        "section_tools",
        "tools_discovered_json",
        "section_advanced",
        "command",
        "args",
        "env_vars",
        "section_notes",
        "notes"
    ],
    "fields": [
        {
            "fieldname": "server_name",
            "fieldtype": "Data",
            "label": "Server Name",
            "reqd": 1,
            "unique": 1,
            "in_list_view": 1,
            "bold": 1,
            "description": "Unique name for this MCP server (e.g., Frappe Assistant Core)"
        },
        {
            "fieldname": "is_active",
            "fieldtype": "Check",
            "label": "Active",
            "default": "1",
            "in_list_view": 1,
            "bold": 1
        },
        {
            "fieldname": "column_break_1",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "transport_type",
            "fieldtype": "Select",
            "label": "Transport",
            "options": "http\nsse\nstreamable-http\nstdio",
            "default": "http",
            "reqd": 1,
            "in_list_view": 1,
            "description": "http = OpenAI-compatible, sse = Server-Sent Events, stdio = Local process"
        },
        {
            "fieldname": "section_connection",
            "fieldtype": "Section Break",
            "label": "Connection"
        },
        {
            "fieldname": "server_url",
            "fieldtype": "Data",
            "label": "Server URL",
            "description": "Full URL to MCP endpoint. For FAC on same server: http://localhost:8000",
            "depends_on": "eval:doc.transport_type != 'stdio'"
        },
        {
            "fieldname": "column_break_2",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "api_key",
            "fieldtype": "Password",
            "label": "API Key / Token",
            "description": "API key for authentication. For same-server FAC, leave blank."
        },
        {
            "fieldname": "section_status",
            "fieldtype": "Section Break",
            "label": "Status"
        },
        {
            "fieldname": "tools_count",
            "fieldtype": "Int",
            "label": "Tools Discovered",
            "read_only": 1,
            "in_list_view": 1,
            "description": "Number of tools discovered from this server"
        },
        {
            "fieldname": "column_break_3",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "last_connected",
            "fieldtype": "Datetime",
            "label": "Last Connected",
            "read_only": 1
        },
        {
            "fieldname": "section_tools",
            "fieldtype": "Section Break",
            "label": "Discovered Tools",
            "collapsible": 1
        },
        {
            "fieldname": "tools_discovered_json",
            "fieldtype": "Code",
            "label": "Tools JSON",
            "read_only": 1,
            "options": "JSON",
            "description": "Auto-populated after connection test"
        },
        {
            "fieldname": "section_advanced",
            "fieldtype": "Section Break",
            "label": "Advanced (stdio only)",
            "collapsible": 1,
            "depends_on": "eval:doc.transport_type == 'stdio'"
        },
        {
            "fieldname": "command",
            "fieldtype": "Data",
            "label": "Command",
            "description": "Command to run for stdio transport (e.g., python3, node)",
            "depends_on": "eval:doc.transport_type == 'stdio'"
        },
        {
            "fieldname": "args",
            "fieldtype": "Data",
            "label": "Arguments",
            "description": "Space-separated arguments for the command",
            "depends_on": "eval:doc.transport_type == 'stdio'"
        },
        {
            "fieldname": "env_vars",
            "fieldtype": "Code",
            "label": "Environment Variables",
            "options": "JSON",
            "description": "JSON object of environment variables",
            "depends_on": "eval:doc.transport_type == 'stdio'"
        },
        {
            "fieldname": "section_notes",
            "fieldtype": "Section Break",
            "label": "Notes",
            "collapsible": 1
        },
        {
            "fieldname": "notes",
            "fieldtype": "Small Text",
            "label": "Notes"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        }
    ],
    "sort_field": "modified",
    "sort_order": "DESC",
    "naming_rule": "By fieldname",
    "autoname": "field:server_name",
    "title_field": "server_name",
    "show_name_in_global_search": 1,
    "track_changes": 1
}
